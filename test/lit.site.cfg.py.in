@LIT_SITE_CFG_IN_HEADER@

import os
import lit.llvm

lit.llvm.initialize(lit_config, config)

config.dnn_mlir_tools_dir = "@CMAKE_BINARY_DIR@/bin"
config.dnn_mlir_obj_root = "@CMAKE_BINARY_DIR@"
config.llvm_tools_dir = "@LLVM_TOOLS_DIR@"
config.dnn_mlir_python_executable = "@DNN_MLIR_PYTHON_EXECUTABLE@"
config.dnn_mlir_torch_mlir_python_packages_dir = \
    "@DNN_MLIR_TORCH_MLIR_PYTHON_PACKAGES_DIR@"
config.dnn_mlir_semantic_tests_enabled = \
    "@DNN_MLIR_SEMANTIC_TESTS_ENABLED@" == "1"

lit_config.load_config(
    config, os.path.join("@CMAKE_CURRENT_SOURCE_DIR@", "lit.cfg.py")
)
