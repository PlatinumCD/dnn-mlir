@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(LLVM CONFIG REQUIRED)
find_dependency(MLIR CONFIG REQUIRED)

list(APPEND CMAKE_MODULE_PATH "${LLVM_CMAKE_DIR}" "${MLIR_CMAKE_DIR}")
include("${CMAKE_CURRENT_LIST_DIR}/DNNMLIRTorchMLIR.cmake")
dnn_mlir_configure_torch_mlir()

include("${CMAKE_CURRENT_LIST_DIR}/DNNMLIRTargets.cmake")

set(DNNMLIR_INCLUDE_DIRS
  "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@"
  ${MLIR_INCLUDE_DIRS}
  ${LLVM_INCLUDE_DIRS}
)
set_property(TARGET DNNMLIR::DNNIR DNNMLIR::DNNTorchToDNN APPEND PROPERTY
  INTERFACE_INCLUDE_DIRECTORIES "${MLIR_INCLUDE_DIRS};${LLVM_INCLUDE_DIRS}"
)
check_required_components(DNNMLIR)
